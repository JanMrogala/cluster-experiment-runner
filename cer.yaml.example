cluster:
  host: "hostname"                           # SSH host (matches ~/.ssh/config)
  base_dir: "/scratch/project_xxx/user/experiments"  # Root directory on LUMI
  repo_url: "git@github.com:user/repo.git"      # GitHub repo SSH URL
  repo_branch: "main"                           # Branch to fetch

container:
  image: "/scratch/project_xxx/user/containers/experiment.sif"  # Singularity .sif on LUMI
  bind_mounts:                                   # Extra --bind mounts
    - "/scratch/project_xxx/user/data:/data"

slurm:
  partition: "gpu"
  gres: "gpu:1"
  cpus_per_task: 8
  mem: "32G"
  time: "24:00:00"
  extra_flags: []                             # Additional #SBATCH flags, e.g. ["--exclusive"]

experiment:
  entrypoint: "python train.py"               # Command run inside container
  wandb_project: "my-project"
  wandb_entity: ""                            # Optional W&B entity/team
  wandb_api_key: ""                           # W&B API key (from https://wandb.ai/authorize)

local:
  db_path: "~/.local/share/cer/experiments.db"
  max_workspaces: 10                          # Max parallel agent workspaces
